# PostgreSQL (docker-compose postgres bilan bir xil bo'lishi kerak)
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/avtopro_db?schema=public"

# Telegram Bot (BotFather dan olingan token)
BOT_TOKEN="your_bot_token_here"

# JWT (admin login uchun; productionda mustaqil kalit yarating)
JWT_SECRET="avtopro-erp-secret-change-in-production"

# Backend port (qat'iy 3000; WebApp 3001 da)
PORT=3000

# Telegram WebApp manzili (HTTPS). Majburiy — bo'lmasa bot ishga tushmaydi.
# Lokalda test qilish uchun: npx localtunnel --port 3001 qilib olingan URLni shu yerga qo'ying.
# Barqaror bo'lmasa: npx ngrok http 3001 — ngrok URLni WEBAPP_URL=... qilib qo'ying.
# WEBAPP_URL=https://your-subdomain.loca.lt
