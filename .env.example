# ─────────────────────────────────────────────────────────────────────────────
# AVTO-PRO Backend .env — HAR BIR KALIT FAQAT BITTA QATORDA BO'LSHIN.
# Takrorlangan kalitlar (masalan 2 marta BOT_TOKEN) xatolik keltiradi.
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://postgres:admin123@localhost:5432/avtopro_db?schema=public"

BOT_TOKEN="<BotFather dan olingan token>"

JWT_SECRET="avtopro-erp-secret-change-in-production"

PORT=3000

WEBAPP_URL="https://<cloudflare yoki ngrok WebApp tunnel manzili>"

# Production (Render): backend ning tashqi URL; bot webhook shu manzilga ulanadi.
# Lokalda bo‘lmasa bot polling rejimida ishlaydi.
# PUBLIC_URL="https://ustabobo-backend.onrender.com"

TELEGRAM_BOT_USERNAME="<bot username, masalan Usta_test_bot>"

# InitData sessiya muddati (soniya). Default 300 (5 min). Dev da 3600 qilish mumkin.
# TELEGRAM_INIT_DATA_MAX_AGE_SEC=300

# Redis (BullMQ). Bitta variantni ishlating:
# 1) REDIS_URL — Redis Cloud / Render (TLS avtomatik rediss:// uchun):
# REDIS_URL=rediss://default:<PASSWORD>@<host>:<port>
# 2) Yoki host/port/password (lokal yoki TLS bo‘lmagan):
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# S3 / MinIO (ixtiyoriy — bo‘lmasa lokal uploads/ ishlatiladi)
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=ustabobo
