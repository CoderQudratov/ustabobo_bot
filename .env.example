# ─────────────────────────────────────────────────────────────────────────────
# AVTO-PRO Backend .env — HAR BIR KALIT FAQAT BITTA QATORDA BO'LSHIN.
# Takrorlangan kalitlar (masalan 2 marta BOT_TOKEN) xatolik keltiradi.
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://postgres:admin123@localhost:5432/avtopro_db?schema=public"

BOT_TOKEN="<BotFather dan olingan token>"

JWT_SECRET="avtopro-erp-secret-change-in-production"

PORT=3000

WEBAPP_URL="https://<cloudflare yoki ngrok WebApp tunnel manzili>"

TELEGRAM_BOT_USERNAME="<bot username, masalan Usta_test_bot>"

# InitData sessiya muddati (soniya). Default 300 (5 min). Dev da 3600 qilish mumkin.
# TELEGRAM_INIT_DATA_MAX_AGE_SEC=300
